# =============================================================================
# Car Fever — Environment Variables
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to:  .env.local
# 2. Fill in your Supabase project credentials
# 3. Restart the dev server: npm run dev
#
# Find these values in Supabase Dashboard → Project Settings → API
# =============================================================================

# Public (safe for browser — used by client components)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only (NEVER expose to browser — used by Server Actions)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Database connection string for running migrations:
# Get from Supabase Dashboard → Project Settings → Database → Connection string
# Replace YOUR_PASSWORD with the database password
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
